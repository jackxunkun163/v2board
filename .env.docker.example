# ====== V2Board Docker deployment (.env.docker) ======
# Consumed by docker-compose.yml. This is NOT the app's own .env (that one is
# generated inside the container from these values on first boot).
#
# Copy to `.env.docker` and edit before `docker compose up`.
# The stack is fully self-contained — MySQL and Redis run as sibling containers.

# --- Web ---
V2BOARD_PORT=8080            # host port mapped to container :80
APP_URL=https://v2board.example.com
APP_ENV=production
APP_DEBUG=false

# APP_KEY is the JWT signing key. Leave blank to auto-generate and persist
# across rebuilds (cached in the storage volume). Set explicitly ONLY if you
# want to pin it (e.g. sharing across replicas). Format: base64:RANDOM_BYTES
APP_KEY=

# --- MySQL (runs in the `mysql` service) ---
DB_DATABASE=v2board
DB_USERNAME=v2board
DB_PASSWORD=change-me-strong-pw
DB_ROOT_PASSWORD=change-me-root-pw

# --- Redis (runs in the `redis` service) ---
# Leave REDIS_PASSWORD blank unless you also edit docker-compose.yml to enable Auth.
REDIS_PASSWORD=

# --- First-boot admin (used once to seed v2_user; safe to leave blank) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars
